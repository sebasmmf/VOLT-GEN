<style>
    .card-wrapper-units {
        height: 50vh;
        width: 90vw;
        border: 1px solid var(--primary-color);
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        position: relative;
    }

    .card-image-container {
        height: 50%;
        width: 100%;
    }

    .card-image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover; 
    }

    .card-info {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        justify-content: space-between;
        padding: 16px;
    }

    .card-details {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .price-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .unit-price {
        font-size: 24px;
        font-weight: bold;
        color: var(--primary-color);
    }

    .add-to-cart-btn {
        background-color: var(--primary-color);
        border: none;
        border-radius: 4px;
        padding: 8px 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
    }

    .badge {
        height: fit-content;
        width: fit-content;
        padding: 4px 8px;
        border-radius: 2px;
        background-color: var(--primary-color);
        position: absolute;
        top: 10px;
        left: 10px;
        font-size: 10px;
        font-weight: bold;
    }
</style>

<div class="card-wrapper-units">
    {% comment %} <div class="badge" style="background-color: var({{ badge_background_color }}); color: var({{ badge_text_color }});">
        <span>{{ badge_text | upcase }}</span>

    </div> {% endcomment %}

    <div class="card-image-container">
        {% if product_image != blank %}
            {{ product_image | image_url: width: 600 | image_tag }}
        {% endif %}
    </div>

    <div class="card-info">
        <div class="card-details">
            <h3>{{ prod.title }}</h3>
            <p>{{ card_paragraph }}</p>
        </div>
        <div class="price-row">
            <span class="unit-price">&dollar;{{ unit_price }}</span>
            <button class="add-to-cart-btn">
                <img src="{{ 'add-to-cart-icon.svg' | asset_url }}" alt="Cart Icon" width="21" height="21"/>
            </button>
        </div>
    </div>
</div>