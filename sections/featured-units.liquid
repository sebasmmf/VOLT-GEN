<style>

    /* Etiqueta que embuelve la sección */
    .featured-units {
        padding: 32px 16px;
    }

    .featured-units-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .btn-link {
        font-size: 14px;
        color: var(--primary-color);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .featured-units-collection {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

</style>


{% comment %} Encabezado de la sección de productos destacados {% endcomment %}
<div class="featured-units-header">
    {% render 'heading-title', 
        title: section.settings.title,
        title_color: section.settings.title_color 
    %}
    <a href="{{ section.settings.btn_link }}" class="btn-link">
        {{ section.settings.btn_text }}
        <img src="{{ 'arrow-right-icon.svg' | asset_url }}" alt="Arrow Right" width="12" height="12"/>
    </a>
</div>

{% comment %} Coleccion de productos destacados {% endcomment %}
<div class="featured-units-collection">
    {% comment %} Card de producto destacado {% endcomment %}
    {% render 'featured-product-card',
        product_image: section.settings.product_image,
        series_title: section.settings.series_title,
        card_paragraph: section.settings.card_paragraph,
        unit_price: section.settings.unit_price,
        badge_background_color: section.settings.badge_background_color,
        badge_text_color: section.settings.badge_text_color,
        badge_text: section.settings.badge_text
    %}
    {% render 'featured-product-card',
        product_image: section.settings.product_image_2,
        series_title: section.settings.series_title_2,
        card_paragraph: section.settings.card_paragraph_2,
        unit_price: section.settings.unit_price_2,
        badge_background_color: section.settings.badge_background_color_2,
        badge_text_color: section.settings.badge_text_color_2,
        badge_text: section.settings.badge_text_2
    %}
</div>


{% schema %}
{
    "name": "Featured Units",
    "tag": "section",
    "class": "featured-units",
    "settings": [
        {
            "type": "image_picker",
            "id": "product_image",
            "label": "Product Image",
        },
        {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Featured Units"
        },
        {
            "type": "select",
            "id": "title_color",
            "label": "Title Color",
            "default": "--secondary-color",
            "options": [
                {
                    "value": "--primary-color",
                    "label": "Primary Color"
                },
                {
                    "value": "--secondary-color",
