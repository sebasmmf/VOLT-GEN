            "label": "Button Text",
            "default": "View All"
        },
        {
            "type": "url",
            "id": "btn_link",
            "label": "Button URL",
            "default": "/collections/all"
        },

        {
            "type": "text",
            "id": "series_title",
            "label": "Series Title",
            "default": "VOLT-P8000 Pro Series"
        },
        {
            "type": "textarea",
            "id": "card_paragraph",
