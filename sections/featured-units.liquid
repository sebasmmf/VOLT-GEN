            "options": [
                {
                    "value": "--primary-color",
                    "label": "Primary Color"
                },
                {
                    "value": "--secondary-color",
                    "label": "Secondary Color"
                },
                {
                    "value": "--tertiary-color",
                    "label": "Tertiary Color"
                },
                {
                    "value": "--neutral-color",
                    "label": "Neutral Color"
                },
            ],
        },
        {
            "type": "select",
            "id": "badge_text_color",
            "label": "Badge Text Color",
            "default": "--neutral-color",
            "options": [
                {
                    "value": "--primary-color",
                    "label": "Primary Color"
                },
                {
                    "value": "--secondary-color",
                    "label": "Secondary Color"
                },
                {
                    "value": "--tertiary-color",
                    "label": "Tertiary Color"
                },
                {
                    "value": "--neutral-color",
                    "label": "Neutral Color"
                },
            ],
        },
        {
            "type": "text",
            "id": "badge_text",
            "label": "Badge Text",
            "default": "Best Seller"
        },

        {
            "type": "image_picker",
            "id": "product_image_2",
            "label": "Product Image 2",
        },
        {
            "type": "text",
            "id": "series_title_2",
            "label": "Series Title 2",
            "default": "VOLT-S20k Standby"
        },
        {
            "type": "textarea",
            "id": "card_paragraph_2",
